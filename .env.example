# Backend Configuration
NODE_ENV=development
PORT=5000

# MongoDB Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/bookingslot

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Gmail SMTP Configuration (OTP Emails)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-app-specific-password

# Admin Configuration
ADMIN_EMAIL=hemaswarupbande5@gmail.com

# OTP Configuration
OTP_EXPIRY_MINUTES=5
MAX_OTP_REQUESTS=5
OTP_RATE_LIMIT_MINUTES=1

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Session Configuration
DEFAULT_SESSION_SLOT_DURATION_MINUTES=30

# Server Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
LOG_LEVEL=debug

# Email Configuration
EMAIL_FROM_NAME=Review Slot System
EMAIL_SUPPORT=support@reviewslot.com

# Features
ENABLE_REAL_TIME_UPDATES=true
ENABLE_ANALYTICS=true
ENABLE_EXPORT=true
